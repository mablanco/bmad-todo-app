# -----------------------------------------------
# bmad-todo-app API — environment configuration
# Copy this file to .env and adjust as needed.
# -----------------------------------------------

# Database connection URL.
# Defaults to a local SQLite file (bmad_todo.db) in the api/ directory.
# For PostgreSQL: postgresql+psycopg2://user:password@localhost:5432/bmad_todo
DATABASE_URL=sqlite:///./bmad_todo.db

# Logging level for the application logger.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Comma-separated list of allowed frontend origins for browser access.
# Defaults include local Vite dev and Playwright ports if not set.
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
